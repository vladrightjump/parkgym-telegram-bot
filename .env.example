# Copy to .env and fill in. NEVER commit the real .env (it is git-ignored).

# ── Telegram ──
# Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=<bot token>
# Random string; also passed to setWebhook so inbound requests can be verified.
TELEGRAM_WEBHOOK_SECRET=<random secret>
# The group chat id where the attendance poll is posted (negative for groups).
TELEGRAM_GROUP_CHAT_ID=<-100...>
# Comma-separated admin chat ids that receive the morning summary DM.
TELEGRAM_ADMIN_CHAT_IDS=<id1,id2>

# ── Supabase (shared with the gym-app web project) ──
# Project URL, e.g. https://<ref>.supabase.co
SUPABASE_URL=https://<project-ref>.supabase.co
# Service-role key (Project Settings -> API). Bypasses RLS — NEVER expose it.
SUPABASE_SERVICE_ROLE_KEY=<service-role key>

# ── Runtime ──
# Gym timezone; drives cron scheduling and "today"/"tomorrow" calendar days.
TZ=Europe/Chisinau
# Port the webhook HTTP server listens on (Railway injects PORT automatically).
PORT=3000
# Public URL of this Railway service — used by `npm run set-webhook`.
PUBLIC_URL=https://<your-service>.up.railway.app
