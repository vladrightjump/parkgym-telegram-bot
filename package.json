{
  "name": "parkgym-telegram-bot",
  "version": "1.0.0",
  "private": true,
  "description": "parkgym.fit attendance bot — Telegram webhook + scheduled polls, running as a Railway worker. Extracted from the gym-app Next.js project.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "node --import tsx --test test/*.test.ts",
    "set-webhook": "tsx scripts/set-webhook.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
